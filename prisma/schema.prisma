generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  MID_ADMIN
  MANAGER
  AGENT
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubStatus {
  ACTIVE
  GRACE
  LOCKED
  CANCELLED
}

enum AdminTier {
  SUPPORT
  FINANCE
  FULL_ACCESS
}

// Preset capability bundle for a non-manager office user.
// See lib/office-permissions.ts for the capability map.
// AGENT is the default — legacy agents predating this feature are backfilled to AGENT.
enum OfficeMemberRole {
  AGENT
  BRANCH_MANAGER
  ACCOUNTANT
  RECEPTIONIST
  MARKETING
  CUSTOM
}

// Controls whether an AdminAccessRule matches trial-only, paid-only, or both.
enum TrialFilter {
  ANY
  TRIAL_ONLY
  PAID_ONLY
}

enum PhotoProcessMode {
  ALWAYS
  NEVER
  ASK
}

enum TicketCategory {
  BILLING
  TECHNICAL
  ACCOUNT
  FEATURE_REQUEST
  BUG_REPORT
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TransactionType {
  SALE
  LONG_TERM_RENT
  SHORT_TERM_RENT
  PRE_SALE
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  LAND
  COMMERCIAL
  OFFICE
  OTHER
}

enum FileStatus {
  ACTIVE
  ARCHIVED
  SOLD
  RENTED
  EXPIRED
}

enum ContactType {
  OWNER
  TENANT
  LANDLORD
  BUYER
}

enum CustomerType {
  BUYER
  RENTER
  SELLER
  LANDLORD
}

enum MessageChannel {
  SMS
  NOTIFICATION
  EMAIL
}

enum CalendarEventType {
  REMINDER
  NOTE
  MEETING
}

// ─── Models ───────────────────────────────────────────────────────────────────

// Office is the tenant root. Every other entity belongs to an office via officeId.
model Office {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  email        String?
  address      String?
  city         String?
  // Office logo and bio — shown on public share pages
  logoUrl        String?
  officeBio      String?
  // Photo processing preferences — defaults to ALWAYS enhance and ALWAYS watermark
  photoEnhancementMode  PhotoProcessMode  @default(ALWAYS)
  watermarkMode         PhotoProcessMode  @default(ALWAYS)
  // Bank details for referral commission payouts — filled in by the office manager
  cardNumber     String?
  shebaNumber    String?
  cardHolderName String?
  // Referral code entered at registration — identifies the referrer, not this office.
  referralCode String?
  // When true, the manager appears in the agents list and can be assigned to files.
  // Default true preserves existing behavior. Only changeable on PRO/TEAM plans.
  managerIsAgent Boolean @default(true)
  // Soft delete — null means active, set means archived. Data is never hard-deleted.
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  users            User[]
  subscription     Subscription?
  files            PropertyFile[]
  customers        Customer[]
  contracts        Contract[]
  paymentRecords   PaymentRecord[]
  adminAssignments AdminOfficeAssignment[]
  aiUsageLogs      AiUsageLog[]
  smsUsageLogs     SmsUsageLog[]
  branches         Branch[]
  notes            OfficeNote[]
  // Referral that brought this office to the platform (one office can be referred once)
  referral         Referral?
  // The referral code this office owns and shares with others to earn commissions
  ownReferralCode  ReferralCode?
  supportTickets   SupportTicket[]
  // Referral earning snapshots that included this office as an active referred office
  referralEarningSnapshots ReferralMonthlyEarningOffice[]
  // One-time trial phone record — prevents the same mobile from starting multiple trials
  trialPhone       TrialPhone?
  scheduledSms     ScheduledSms[]
  officeMessages   OfficeMessage[]
  calendarEvents   CalendarEvent[]

  @@map("offices")
}

model User {
  id           String        @id @default(cuid())
  // username is the primary login identifier. Unique globally across all offices.
  username     String        @unique
  // email is optional — agents may have no email. Nullable unique allows multiple NULLs in PostgreSQL.
  email        String?       @unique
  // phone used for SMS-based password reset. Nullable unique allows multiple NULLs.
  phone        String?       @unique
  passwordHash String
  displayName  String
  role         Role
  // Permission tier for MID_ADMIN users. Null = read-only access.
  adminTier    AdminTier?
  isActive              Boolean       @default(true)
  onboardingCompleted   Boolean       @default(false)
  // avatarUrl will be populated by the image processing pipeline (Feature 14)
  avatarUrl    String?
  // Short bio — shown on public share pages
  bio          String?
  // Internal admin note (not visible to the user)
  adminNote    String?
  // When true, this agent is allowed to finalize contracts (normally manager-only).
  // DEPRECATED — superseded by permissionsOverride.finalizeContract. Kept for one release
  // while the migration backfills the override. New code must read through canOfficeDo().
  canFinalizeContracts Boolean @default(false)
  // Preset permission bundle for non-manager office users. Null for MANAGER and admin roles.
  // Resolution: permissionsOverride wins per-capability; otherwise the preset map is used.
  officeMemberRole OfficeMemberRole?
  // Sparse per-capability override ({ finalizeContract: true, createFile: false, ... }).
  // Null or missing keys fall back to the officeMemberRole preset.
  permissionsOverride Json?
  // Nullable: SUPER_ADMIN and MID_ADMIN users have no tenant office (officeId = null)
  officeId     String?
  // Nullable: links user to a specific branch (Team plan multi-branch, hidden until month 4)
  branchId     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  office              Office?          @relation(fields: [officeId], references: [id])
  branch              Branch?          @relation(fields: [branchId], references: [id])
  adminAssignments    AdminOfficeAssignment[]
  adminAccessRules    AdminAccessRule[]
  sessions            UserSession[]
  createdFiles        PropertyFile[]   @relation("CreatedFiles")
  fileAssignments     FileAssignment[]
  activityLogs        ActivityLog[]
  priceHistory        PriceHistory[]
  shareLinks          ShareLink[]      @relation("ShareLinkCreator")
  shareLinkAgentCards ShareLink[]      @relation("ShareLinkAgent")
  notifications       Notification[]
  createdCustomers    Customer[]       @relation("CreatedCustomers")
  customerNotes       CustomerNote[]   @relation("CustomerNotes")
  finalizedContracts  Contract[]       @relation("FinalizedContracts")
  officeNotes         OfficeNote[]
  adminActions        AdminActionLog[]
  adminCreatedCodes   ReferralCode[]   @relation("AdminCreatedReferralCodes")
  adminPaidEarnings   ReferralMonthlyEarning[] @relation("AdminPaidEarnings")
  sentBroadcasts      AdminBroadcast[]
  adminLoginLogs      AdminLoginLog[]  @relation("AdminLoginLogs")
  createdTickets      SupportTicket[]  @relation("TicketCreator")
  ticketMessages      TicketMessage[]
  passwordResetTokens PasswordResetToken[]
  sentMessages        OfficeMessage[]      @relation("SentMessages")
  createdCalendarEvents  CalendarEvent[]           @relation("CalendarEventCreator")
  calendarAttendances    CalendarEventAttendee[]   @relation("CalendarEventAttendees")

  @@map("users")
}

// Tracks active sessions per user. Used to enforce the 2-session limit.
// Does NOT replace the JWT — it is a secondary store for session counting and invalidation.
model UserSession {
  id           String    @id @default(cuid())
  userId       String
  // expiresAt matches the JWT maxAge (30 days). Used for automatic cleanup.
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  // lastActiveAt updated periodically (max every 5 min) for online-user tracking.
  lastActiveAt DateTime?
  // userAgent stored at login for device display in profile sessions panel.
  userAgent    String?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

// One subscription per office. Created automatically on registration.
model Subscription {
  id               String       @id @default(cuid())
  officeId         String       @unique
  plan             Plan         @default(FREE)
  status           SubStatus    @default(ACTIVE)
  // True while the office is on a free trial period (PRO or TEAM trial).
  // FREE plan offices never have a trial — isTrial stays false.
  isTrial          Boolean      @default(false)
  billingCycle     BillingCycle @default(MONTHLY)
  // Set to now + 30 days at registration for trial offices. Null for FREE plan.
  trialEndsAt      DateTime?
  // Set when the office makes a successful payment. Governs paid plan expiry.
  currentPeriodEnd DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  office           Office    @relation(fields: [officeId], references: [id])

  @@map("subscriptions")
}

// A property listing (فایل). Minimum to create: transactionType + location + 1 contact.
model PropertyFile {
  id              String          @id @default(cuid())
  officeId        String
  createdById     String
  transactionType TransactionType
  status          FileStatus      @default(ACTIVE)
  propertyType    PropertyType?

  // Physical details
  area            Int?            // square meters (متراژ)
  floorNumber     Int?
  totalFloors     Int?
  buildingAge     Int?            // years (سن بنا)

  // Price fields — which are used depends on transactionType
  salePrice       BigInt?         // total price in Toman (for SALE, PRE_SALE)
  depositAmount   BigInt?         // رهن in Toman (for LONG_TERM_RENT)
  rentAmount      BigInt?         // monthly اجاره in Toman (for LONG_TERM_RENT, SHORT_TERM_RENT)

  // Location — map pin stored as lat/lng. Address filled manually until map feature is built.
  latitude        Float?
  longitude       Float?
  address         String?
  neighborhood    String?
  // Neshan POI analysis stored as JSON after location is pinned (Feature 13)
  locationAnalysis Json?

  // AI-generated or manually written description
  description     String?

  // Amenities
  hasElevator      Boolean         @default(false)
  hasParking       Boolean         @default(false)
  hasStorage       Boolean         @default(false)
  hasBalcony       Boolean         @default(false)
  hasSecurity      Boolean         @default(false)
  hasGym           Boolean         @default(false)
  hasPool          Boolean         @default(false)
  hasWesternToilet Boolean         @default(false)
  hasSmartHome     Boolean         @default(false)
  hasSauna         Boolean         @default(false)
  hasJacuzzi       Boolean         @default(false)
  hasRoofGarden    Boolean         @default(false)

  // Internal notes — not shown on public share page
  notes           String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  office          Office          @relation(fields: [officeId], references: [id])
  createdBy       User            @relation("CreatedFiles", fields: [createdById], references: [id])
  assignedAgents  FileAssignment[]
  contacts        Contact[]
  photos          FilePhoto[]
  activityLogs    ActivityLog[]
  priceHistory    PriceHistory[]
  shareLinks      ShareLink[]
  contract        Contract?
  notifications   Notification[]

  @@index([officeId])
  @@index([officeId, status])
  @@map("property_files")
}

// Tracks which agents are assigned to a file.
model FileAssignment {
  id         String       @id @default(cuid())
  fileId     String
  userId     String
  assignedAt DateTime     @default(now())

  file       PropertyFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id])

  @@unique([fileId, userId])
  @@map("file_assignments")
}

// Contacts linked to a file (owner, tenant, buyer, landlord).
model Contact {
  id        String       @id @default(cuid())
  fileId    String
  type      ContactType
  name      String?
  phone     String
  notes     String?
  createdAt DateTime     @default(now())

  file      PropertyFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

// Photo records for a file. URL points to IranServer object storage (Feature 14).
model FilePhoto {
  id        String       @id @default(cuid())
  fileId    String
  url       String
  order     Int          @default(0)
  createdAt DateTime     @default(now())

  file      PropertyFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("file_photos")
}

// Immutable log of all file changes. Visible to managers only.
model ActivityLog {
  id        String       @id @default(cuid())
  fileId    String
  userId    String
  // Human-readable action label: CREATE, EDIT, STATUS_CHANGE, ASSIGNMENT, SHARE_LINK
  action    String
  // Field-level diff stored as JSON: { field: [oldValue, newValue] }
  diff      Json?
  createdAt DateTime     @default(now())

  file      PropertyFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id])

  @@index([fileId])
  @@map("activity_logs")
}

// Records every price change on a file with before/after values.
model PriceHistory {
  id          String       @id @default(cuid())
  fileId      String
  changedById String
  // Which price field changed: salePrice | depositAmount | rentAmount
  priceField  String
  oldPrice    BigInt?
  newPrice    BigInt?
  changedAt   DateTime     @default(now())

  file        PropertyFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  changedBy   User         @relation(fields: [changedById], references: [id])

  @@index([fileId])
  @@map("price_history")
}

// CRM customer — can be buyer, renter, seller, and/or landlord (multi-type).
model Customer {
  id          String         @id @default(cuid())
  officeId    String
  createdById String
  name        String
  phone       String
  email       String?
  // Multi-type: a customer can be BUYER and RENTER simultaneously
  types       CustomerType[]
  // Internal notes about this customer
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  office             Office            @relation(fields: [officeId], references: [id])
  createdBy          User              @relation("CreatedCustomers", fields: [createdById], references: [id])
  contactLogs        CustomerNote[]
  shareLinks         ShareLink[]
  contractCustomers  ContractCustomer[]

  @@index([officeId])
  @@map("customers")
}

// A timestamped interaction note logged against a customer.
model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  userId     String
  content    String
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user       User     @relation("CustomerNotes", fields: [userId], references: [id])

  @@index([customerId])
  @@map("customer_notes")
}

// Links a CRM customer to a contract with their role in that transaction.
model ContractCustomer {
  id         String       @id @default(cuid())
  contractId String
  customerId String
  // The customer's role in this specific contract (BUYER, TENANT/RENTER, etc.)
  role       CustomerType

  contract   Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([contractId, customerId])
  @@map("contract_customers")
}

// A finalized deal. Created by the manager when a transaction closes.
// Creating a contract atomically transitions the file to SOLD or RENTED and
// deactivates all share links.
model Contract {
  id              String          @id @default(cuid())
  officeId        String
  // fileId is unique — one contract per file
  fileId          String          @unique
  finalizedById   String
  // Copied from the file at finalization time for archival integrity
  transactionType TransactionType
  // Final agreed price used as the basis for commission calculation.
  // BigInt — Iranian real estate prices exceed PostgreSQL INTEGER's ~2.1B Toman limit.
  finalPrice       BigInt
  // Commission breakdown — all amounts in Toman
  commissionAmount BigInt
  agentShare       BigInt
  officeShare      BigInt
  notes           String?
  // Months the lease runs. Only set for LONG_TERM_RENT contracts. Used to derive lease-end date.
  leaseDurationMonths Int?
  finalizedAt     DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  office            Office            @relation(fields: [officeId], references: [id])
  file              PropertyFile      @relation(fields: [fileId], references: [id])
  finalizedBy       User              @relation("FinalizedContracts", fields: [finalizedById], references: [id])
  scheduledSms      ScheduledSms?
  contractCustomers ContractCustomer[]

  @@index([officeId])
  @@map("contracts")
}

// Each share action creates a new unique link with its own price and view counter.
model ShareLink {
  id          String       @id @default(cuid())
  fileId      String
  createdById String
  // The agent whose profile card is shown on the public share page.
  // Null = no agent card shown (office card only).
  agentId     String?
  token       String       @unique
  // Custom price overrides. For SALE/PRE_SALE: customPrice = sale price.
  // For SHORT_TERM_RENT: customPrice = rent amount.
  // For LONG_TERM_RENT: customPrice = اجاره (rent), customDepositAmount = رهن (deposit).
  customPrice         BigInt?
  customDepositAmount BigInt?
  viewCount   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  // Optional CRM customer this link was sent to
  customerId  String?

  file        PropertyFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("ShareLinkCreator", fields: [createdById], references: [id])
  agent       User?        @relation("ShareLinkAgent", fields: [agentId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([token])
  @@map("share_links")
}

// Per-user notification record. Created server-side on key events.
model Notification {
  id        String        @id @default(cuid())
  userId    String
  // FILE_ASSIGNED | FILE_EDITED
  type      String
  title     String
  message   String
  read      Boolean       @default(false)
  // Optional deep-link to the relevant file
  fileId    String?
  createdAt DateTime      @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  file      PropertyFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

// Tracks Zarinpal payment attempts. Created when a payment is initiated so the
// verify callback can look up the office without a user session.
model PaymentRecord {
  id           String       @id @default(cuid())
  officeId     String
  plan         Plan
  billingCycle BillingCycle @default(MONTHLY)
  // Amount stored in Rials (Zarinpal unit = Toman × 10)
  amount       Int
  // Zarinpal's unique payment identifier — used as the lookup key in the callback
  authority    String       @unique
  // PENDING → VERIFIED on success, FAILED on verification failure
  status       String       @default("PENDING")
  // Zarinpal ref_id returned on successful verification
  refId        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  office       Office   @relation(fields: [officeId], references: [id])

  @@index([officeId])
  @@map("payment_records")
}

// Tracks AI description generation calls per office per Shamsi calendar month.
// Used to enforce the FREE plan limit of 10 AI calls/month.
// shamsiMonth is stored as a YYYYMM integer (e.g. 140412 = Farvardin 1404).
model AiUsageLog {
  id          String @id @default(cuid())
  officeId    String
  shamsiMonth Int
  count       Int    @default(0)

  office      Office @relation(fields: [officeId], references: [id])

  @@unique([officeId, shamsiMonth])
  @@map("ai_usage_logs")
}

// Tracks SMS sends per office per Shamsi calendar month.
// Used to enforce the FREE plan soft cap on share SMS sends.
// shamsiMonth is stored as a YYYYMM integer (e.g. 140412 = Farvardin 1404).
model SmsUsageLog {
  id          String @id @default(cuid())
  officeId    String
  shamsiMonth Int
  count       Int    @default(0)

  office      Office @relation(fields: [officeId], references: [id])

  @@unique([officeId, shamsiMonth])
  @@map("sms_usage_logs")
}

// Office branch for multi-branch management (Team plan).
// Schema included at launch; UI and enforcement enabled at month 4.
model Branch {
  id        String   @id @default(cuid())
  officeId  String
  name      String
  address   String?
  createdAt DateTime @default(now())

  office    Office   @relation(fields: [officeId], references: [id])
  users     User[]

  @@index([officeId])
  @@map("branches")
}

// Dynamic access rule for a MID_ADMIN — offices matching any rule are accessible,
// evaluated live at request time so newly-registered offices join automatically.
// Within one rule, fields are AND'd (city AND plan AND trial). Multiple rules are OR'd.
// Empty cities[] / plans[] = no constraint on that dimension. Explicit AdminOfficeAssignment
// rows still grant access in addition to rule-based matches.
model AdminAccessRule {
  id          String      @id @default(cuid())
  adminUserId String
  // Empty = match any city. Otherwise office.city must be in this list.
  cities      String[]    @default([])
  // Empty = match any plan. Otherwise office.subscription.plan must be in this list.
  plans       Plan[]      @default([])
  // Controls whether trial offices match: ANY (both), TRIAL_ONLY, or PAID_ONLY.
  trialFilter TrialFilter @default(ANY)
  createdAt   DateTime    @default(now())

  admin       User @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@map("admin_access_rules")
}

// Links a MID_ADMIN user to specific offices they are allowed to support.
// SUPER_ADMIN has unrestricted access and does not use this table.
model AdminOfficeAssignment {
  id          String   @id @default(cuid())
  adminUserId String
  officeId    String
  assignedAt  DateTime @default(now())

  admin       User   @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  office      Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, officeId])
  @@index([adminUserId])
  @@map("admin_office_assignments")
}

// Audit log for every admin mutation — written on every PATCH/POST/DELETE from admin API routes.
model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  // Human-readable action: UPDATE_SUBSCRIPTION, TOGGLE_USER_ACTIVE, SUSPEND_OFFICE, etc.
  action     String
  // The entity type being acted on: OFFICE | USER | SUBSCRIPTION | MID_ADMIN
  targetType String
  targetId   String
  // Optional before/after state or supporting context stored as JSON
  metadata   Json?
  createdAt  DateTime @default(now())

  admin      User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@map("admin_action_logs")
}

// Admin-internal notes attached to an office — not visible to the office manager.
model OfficeNote {
  id        String   @id @default(cuid())
  officeId  String
  adminId   String
  content   String
  createdAt DateTime @default(now())

  office    Office @relation(fields: [officeId], references: [id], onDelete: Cascade)
  admin     User   @relation(fields: [adminId], references: [id])

  @@index([officeId])
  @@map("office_notes")
}

// A referral code — may belong to an office (auto-generated) or be standalone (partner code).
model ReferralCode {
  id                          String   @id @default(cuid())
  code                        String   @unique
  // null for partner/standalone codes that don't belong to any single office
  officeId                    String?  @unique
  office                      Office?  @relation(fields: [officeId], references: [id])
  label                       String?
  // Toman per active referred office per month (0 for auto-generated office codes)
  commissionPerOfficePerMonth Int      @default(0)
  isActive                    Boolean  @default(true)
  createdAt                   DateTime @default(now())
  createdByAdminId            String?
  createdByAdmin              User?    @relation("AdminCreatedReferralCodes", fields: [createdByAdminId], references: [id])

  referrals       Referral[]
  monthlyEarnings ReferralMonthlyEarning[]

  @@map("referral_codes")
}

// Records which referral code brought a given office to the platform.
// Each office can only be referred once (officeId is unique).
model Referral {
  id             String       @id @default(cuid())
  referralCodeId String
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id])
  // officeId is unique — each office can only be referred once
  officeId       String       @unique
  office         Office       @relation(fields: [officeId], references: [id])
  createdAt      DateTime     @default(now())

  @@map("referrals")
}

// Monthly commission snapshot for a referral code.
// yearMonth is Gregorian YYYY-MM (e.g. "2026-03").
model ReferralMonthlyEarning {
  id                String       @id @default(cuid())
  referralCodeId    String
  referralCode      ReferralCode @relation(fields: [referralCodeId], references: [id])
  yearMonth         String       // "2026-03"
  activeOfficeCount Int
  // commissionAmount = activeOfficeCount * code.commissionPerOfficePerMonth at snapshot time
  commissionAmount  BigInt
  isPaid            Boolean      @default(false)
  paidAt            DateTime?
  paidByAdminId     String?
  paidByAdmin       User?        @relation("AdminPaidEarnings", fields: [paidByAdminId], references: [id])
  createdAt         DateTime     @default(now())

  // Which offices were counted as active when this snapshot was generated
  activeOffices     ReferralMonthlyEarningOffice[]

  @@unique([referralCodeId, yearMonth])
  @@map("referral_monthly_earnings")
}

// Records which specific offices were counted in a monthly earning snapshot.
// Populated/replaced each time the snapshot is (re)generated.
model ReferralMonthlyEarningOffice {
  earningId String
  officeId  String

  earning   ReferralMonthlyEarning @relation(fields: [earningId], references: [id], onDelete: Cascade)
  office    Office                 @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@id([earningId, officeId])
  @@map("referral_monthly_earning_offices")
}

// Record of admin broadcast messages sent to office managers.
model AdminBroadcast {
  id             String    @id @default(cuid())
  subject        String
  body           String
  // "ONE" | "ALL" | "FILTERED"
  targetType     String
  targetOfficeId String?
  // for FILTERED: e.g. { plan: "FREE", status: "ACTIVE" }
  targetFilter   Json?
  recipientCount Int
  sendSms        Boolean   @default(false)
  sentAt         DateTime  @default(now())
  sentByAdminId  String
  sentByAdmin    User      @relation(fields: [sentByAdminId], references: [id])

  @@map("admin_broadcasts")
}

// Records each admin sign-in with IP and user-agent for security auditing.
model AdminLoginLog {
  id        String   @id @default(cuid())
  adminId   String
  ipAddress String?
  userAgent String?
  loginAt   DateTime @default(now())

  admin     User     @relation("AdminLoginLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("admin_login_logs")
}

// OTP token for SMS-based password reset. Stored as SHA-256 hash — never plaintext.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SHA-256 hex of the raw 6-digit OTP — the raw OTP is sent by SMS and never stored.
  tokenHash String   @unique
  expiresAt DateTime
  // Marked true after the token is used — prevents reuse even before expiry.
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// Key-value store for platform-wide settings editable by SUPER_ADMIN.
model PlatformSetting {
  key              String   @id
  value            String
  updatedAt        DateTime @updatedAt
  updatedByAdminId String?

  @@map("platform_settings")
}

// A support ticket submitted by a manager or agent.
model SupportTicket {
  id         String         @id @default(cuid())
  officeId   String
  createdBy  String
  subject    String
  category   TicketCategory
  status     TicketStatus   @default(OPEN)
  closedAt   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  office     Office         @relation(fields: [officeId], references: [id])
  creator    User           @relation("TicketCreator", fields: [createdBy], references: [id])
  messages   TicketMessage[]

  @@index([officeId])
  @@index([officeId, status])
  @@map("support_tickets")
}

// A message in a support ticket thread (user reply or admin reply).
model TicketMessage {
  id            String        @id @default(cuid())
  ticketId      String
  authorId      String
  isAdminReply  Boolean       @default(false)
  body          String
  attachmentUrl String?
  createdAt     DateTime      @default(now())

  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author        User          @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@map("ticket_messages")
}

// A rent follow-up SMS scheduled to be sent automatically on a future date.
// Created when the manager chooses to schedule a follow-up on a LONG_TERM_RENT contract.
// One record per contract — replaced (not stacked) if the manager reschedules.
model ScheduledSms {
  id          String    @id @default(cuid())
  officeId    String
  contractId  String    @unique
  phone       String
  message     String    @db.Text
  scheduledAt DateTime
  sentAt      DateTime?
  failedAt    DateTime?
  errorMsg    String?
  createdAt   DateTime  @default(now())

  office      Office    @relation(fields: [officeId], references: [id])
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@map("scheduled_sms")
}

// One record per office that starts a paid trial (PRO or TEAM).
// Prevents the same mobile number from being used for multiple trials.
// Phone is NOT verified by OTP — this is a soft constraint to deter casual abuse.
model TrialPhone {
  id        String   @id @default(cuid())
  phone     String   @unique
  officeId  String   @unique
  createdAt DateTime @default(now())

  office    Office   @relation(fields: [officeId], references: [id])

  @@map("trial_phones")
}

// A message sent by a manager to agents (notification) or customers (SMS/email).
// Saved as a history record after each send.
model OfficeMessage {
  id             String         @id @default(cuid())
  officeId       String
  senderId       String
  channel        MessageChannel
  subject        String?        // used for EMAIL channel
  body           String         @db.Text
  recipientCount Int
  // Human-readable description of the audience: "همه مشاوران", "مشتریان (خریدار)", etc.
  filterLabel    String?
  createdAt      DateTime       @default(now())

  office         Office         @relation(fields: [officeId], references: [id])
  sender         User           @relation("SentMessages", fields: [senderId], references: [id])

  @@index([officeId])
  @@map("office_messages")
}

// A calendar event created by a manager. MEETING events can invite agents.
// REMINDER and NOTE are private to the manager; MEETING creates notifications for attendees.
model CalendarEvent {
  id              String            @id @default(cuid())
  officeId        String
  createdById     String
  title           String?           // optional — NOTE type has no title; REMINDER may be untitled
  description     String?
  type            CalendarEventType
  // Stored as Gregorian ISO timestamp. Only the date part is semantically used.
  eventDate       DateTime
  // Optional HH:MM 24-hour strings. Stored as text to avoid TZ-shift issues.
  startTime       String?
  endTime         String?
  reminderMinutes Int?              // MEETING: minutes before startTime to fire notification. Unused for REMINDER.
  playSound       Boolean           @default(false)  // REMINDER + MEETING: play audio on notification
  // Stamped by /api/cron/fire-calendar-reminders once a reminder fires. Null = never fired (or no reminder configured).
  reminderFiredAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  office    Office                  @relation(fields: [officeId], references: [id], onDelete: Cascade)
  createdBy User                    @relation("CalendarEventCreator", fields: [createdById], references: [id])
  attendees CalendarEventAttendee[]

  @@index([officeId, eventDate])
  @@index([reminderFiredAt, eventDate])
  @@map("calendar_events")
}

// Join table: which agents are invited to a MEETING event.
model CalendarEventAttendee {
  eventId String
  userId  String

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation("CalendarEventAttendees", fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@map("calendar_event_attendees")
}
